# ════════════════════════════════════════════════════════════════
#  Stock Analyser & Auto-Trader — Environment Variables
#  Copy this file to .env and fill in your credentials.
# ════════════════════════════════════════════════════════════════

# ── Personal access key (YOU only — pass as X-API-Key header) ────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=ivzKTwLc0us1J5xV0Xxy6gTVw9WskUOtbJM4KGGgXqU

# ── Zerodha Kite ─────────────────────────────────────────────────
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here
# LOCAL dev  → http://localhost:8000/api/auth/callback
# AWS deploy → https://yourdomain.com/api/auth/callback
KITE_REDIRECT_URL=http://localhost:8000/api/auth/callback

# ── Fyers ────────────────────────────────────────────────────────
# App ID format: XXXXXXXX-100 (from Fyers developer console)
FYERS_APP_ID=your_fyers_app_id_here
FYERS_SECRET=your_fyers_secret_here
FYERS_REDIRECT_URL=http://localhost:8000/api/auth/fyers/callback

# Which broker to use for live trading: zerodha | fyers
ACTIVE_BROKER=zerodha

# ── Anthropic AI ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Email Alerts (Gmail recommended) ────────────────────────────
# For Gmail: enable 2-FA, then create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=yourbot@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_RECIPIENT=sudeepkrishnan87@gmail.com

# ── WhatsApp Alerts (Twilio) ─────────────────────────────────────
# Sign up at https://www.twilio.com, go to Messaging > WhatsApp sandbox
# Text the join code to +1 (415) 523-8886 from your WhatsApp to activate
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Your WhatsApp number with country code (India: +91xxxxxxxxxx)
TWILIO_WHATSAPP_TO=whatsapp:+91xxxxxxxxxx

# ── Trading Capital & Risk Management ────────────────────────────
# Starting capital in INR
TRADING_CAPITAL=100000

# Maximum % of capital risked per single trade (2% = ₹2,000 on ₹1L capital)
MAX_RISK_PER_TRADE_PCT=2.0

# Stop all new trades if daily loss exceeds this % of capital
DAILY_LOSS_LIMIT_PCT=3.0

# Never deploy more than this % of capital simultaneously
MAX_PORTFOLIO_EXPOSURE_PCT=60.0

# Maximum simultaneous open positions
MAX_OPEN_POSITIONS=5

# ── Screener ─────────────────────────────────────────────────────
# How often (minutes) to run intraday scans during market hours
SCAN_INTERVAL_MINUTES=15
